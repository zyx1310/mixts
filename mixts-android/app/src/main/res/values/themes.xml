<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 启动画面主题 - 使用 Splash Screen API -->
    <style name="Theme.Mixts.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/purple_700</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.Mixts</item>
    </style>

    <!-- 主主题 -->
    <style name="Theme.Mixts" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/purple_700</item>
    </style>
</resources>
